# DVPN Environment Config
# Source this file in all scripts: source "$(dirname "$0")/../.env"
# Or from root level: source ~/.env

# Working directory (default: ~/sentinel-dvpncli)
WORK_DIR="${WORK_DIR:-${HOME}/sentinel-dvpncli}"

# RPC endpoints (comma-separated for fallback)
RPC_ENDPOINTS="https://sentinel-rpc.polkachu.com:443,https://sentinel-rpc.publicnode.com:443"

# LCD endpoint
LCD_ENDPOINT="https://lcd.sentinel.co"

# Keyring
KEY_NAME="main"
KEYRING_BACKEND="test"
KEYRING_HOME="${WORK_DIR}"

# Fallback node list (one per line)
FALLBACK_NODES_FILE="${HOME}/fav-providers.lst"

# Country filter (comma-separated ISO codes for node selection)
COUNTRY_FILTER="NL,DE,FR"

# Session defaults
DEFAULT_GIGABYTES="10"
DEFAULT_HOURS="0"
TX_GAS_PRICES="0.1udvpn"
TX_GAS_ADJUSTMENT="1.8"
MAX_PRICE="udvpn:1,30000"